{
  "manifest_version": 3,
  "name": "标签页管理器",
  "version": "1.0",
  "description": "汇总当前窗口中打开的所有标签页面，按域名分组展示",
  "permissions": [
    "tabs",
    "sessions"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}